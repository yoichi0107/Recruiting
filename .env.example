# Resend API key for sending application emails to info@107designinc.com
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# (Optional) Override the "from" address used by Resend.
# Must be a verified domain/sender in your Resend account.
# Defaults to "107 Design Recruit <onboarding@resend.dev>" if unset.
RESEND_FROM_EMAIL=

# (Optional) Override where applications are delivered.
# Defaults to info@107designinc.com if unset.
RECRUIT_TO_EMAIL=
